{
  "name": "CampusOLX - Campus Marketplace",
  "short_name": "CampusOLX",
  "description": "The ultimate AI-powered campus marketplace for students - Light Glass Mobile Experience",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#FFFFFF",
  "theme_color": "#FFFFFF",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "en",
  "categories": ["shopping", "education", "social"],
  "display_override": ["window-controls-overlay", "standalone"],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "icons": [
    {
      "src": "/icons/icon-72x72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-96x96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-128x128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-144x144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-152x152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-384x384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "maskable any"
    },
    {
      "src": "/icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable any"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile-home.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Light Glass Home Screen"
    },
    {
      "src": "/screenshots/mobile-search.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Enhanced Search Experience"
    },
    {
      "src": "/screenshots/mobile-product.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Product Details View"
    }
  ],
  "shortcuts": [
    {
      "name": "Browse Items",
      "short_name": "Browse",
      "description": "Browse marketplace items with AI recommendations",
      "url": "/dashboard",
      "icons": [{ "src": "/icons/shortcut-browse.png", "sizes": "96x96" }]
    },
    {
      "name": "Post Ad",
      "short_name": "Sell",
      "description": "Sell an item with AI pricing",
      "url": "/post-ad",
      "icons": [{ "src": "/icons/shortcut-sell.png", "sizes": "96x96" }]
    },
    {
      "name": "Lost & Found",
      "short_name": "Lost",
      "description": "Lost and found items",
      "url": "/lost-found",
      "icons": [{ "src": "/icons/shortcut-lost.png", "sizes": "96x96" }]
    },
    {
      "name": "Chat",
      "short_name": "Chat",
      "description": "Message other students",
      "url": "/chat",
      "icons": [{ "src": "/icons/shortcut-chat.png", "sizes": "96x96" }]
    }
  ],
  "prefer_related_applications": false,
  "related_applications": [],
  "protocol_handlers": [
    {
      "protocol": "web+campusolx",
      "url": "/product/%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/post-ad",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".webp", ".gif"]
      }
    }
  ],
  "share_target": {
    "action": "/post-ad",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "description",
      "url": "url"
    }
  }
}