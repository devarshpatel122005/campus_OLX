<style>
  /* Hero Section Styles */
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
  }

  .text-gradient-hero {
    background: var(--hero-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-gradient-accent {
    background: linear-gradient(135deg, var(--cyber-purple) 0%, var(--electric-blue) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .text-electric-blue {
    color: var(--electric-blue);
  }

  .text-light-gray {
    color: var(--text-light-gray);
  }

  .hero-title {
    font-size: 4.5rem;
    line-height: 1.1;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
  }

  /* Floating Search Pill */
  .floating-search-pill {
    border-radius: 50px;
    box-shadow: 
      var(--shadow-glass),
      var(--glow-blue);
    transition: all 0.3s ease;
  }

  .floating-search-pill:hover {
    transform: translateY(-2px);
    box-shadow: 
      var(--shadow-hover),
      0 0 30px rgba(59, 130, 246, 0.4);
  }

  /* Feature Cards */
  .feature-card {
    border-radius: 16px;
    transition: all 0.3s ease;
    border: 1px solid var(--glass-border);
  }

  .feature-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--glow-blue);
  }

  .feature-icon-modern {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    background: var(--card-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    color: var(--electric-blue);
    font-size: 1.5rem;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  /* 3D Visual Elements */
  .floating-3d-card {
    border-radius: 30px;
    min-height: 400px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    box-shadow: 
      var(--shadow-glass),
      var(--glow-blue);
  }

  .floating-elements-3d {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }

  .floating-item {
    position: absolute;
    width: 60px;
    height: 60px;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--electric-blue);
    backdrop-filter: blur(10px);
    animation: float-3d 6s ease-in-out infinite;
  }

  .floating-item.book {
    top: 10%;
    left: -10%;
    animation-delay: 0s;
  }

  .floating-item.phone {
    top: 20%;
    right: -10%;
    animation-delay: 1.5s;
  }

  .floating-item.headphones {
    bottom: 30%;
    left: -15%;
    animation-delay: 3s;
  }

  .floating-item.bicycle {
    bottom: 10%;
    right: -5%;
    animation-delay: 4.5s;
  }

  @keyframes float-3d {
    0%, 100% { 
      transform: translateY(0px) rotate(0deg); 
      box-shadow: var(--shadow-glass);
    }
    33% { 
      transform: translateY(-20px) rotate(5deg); 
      box-shadow: var(--shadow-hover), var(--glow-blue);
    }
    66% { 
      transform: translateY(10px) rotate(-5deg); 
      box-shadow: var(--shadow-glass);
    }
  }

  /* Floating Stats */
  .floating-stat {
    position: absolute;
    z-index: 2;
  }

  .floating-stat.top-right {
    top: -10px;
    right: -10px;
  }

  .floating-stat.bottom-left {
    bottom: -10px;
    left: -10px;
  }

  .stat-icon-modern {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--primary-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 1.2rem;
  }

  /* Premium Feature Cards */
  .feature-card-premium {
    border-radius: 20px;
    transition: all 0.4s ease;
    position: relative;
    overflow: hidden;
  }

  .feature-card-premium::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--primary-gradient);
    transform: scaleX(0);
    transition: transform 0.4s ease;
  }

  .feature-card-premium:hover::before {
    transform: scaleX(1);
  }

  .feature-card-premium:hover {
    transform: translateY(-10px);
    box-shadow: 
      var(--shadow-hover),
      var(--glow-blue);
  }

  .feature-icon-large {
    width: 80px;
    height: 80px;
    border-radius: 20px;
    background: var(--primary-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    color: white;
    font-size: 2rem;
    box-shadow: var(--glow-blue);
  }

  .feature-benefits {
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    padding: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .benefit-item {
    display: flex;
    align-items: center;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .benefit-item:last-child {
    margin-bottom: 0;
  }

  /* CTA Section */
  .cta-card {
    border-radius: 25px;
    background: var(--card-gradient);
    border: 1px solid rgba(59, 130, 246, 0.2);
    box-shadow: 
      var(--shadow-glass),
      var(--glow-blue);
  }

  /* Responsive Design */
  @media (max-width: 768px) {
    .hero-title {
      font-size: 3rem;
    }
    
    .hero-subtitle {
      font-size: 1.1rem;
    }
    
    .floating-stat {
      position: static;
      margin: 1rem 0;
    }
    
    .floating-item {
      display: none;
    }
    
    .floating-3d-card {
      min-height: 300px;
    }
  }
</style>
`;
