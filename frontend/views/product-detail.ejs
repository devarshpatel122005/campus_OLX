<% const body=` <div class="container py-4">
    <div class="row">
        <div class="col-lg-8">
            <!-- Image Gallery -->
            <div class="card mb-4">
                ${product.images.length > 0 ? `
                <div id="productCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        ${product.images.map((img, idx) => `
                        <div class="carousel-item ${idx === 0 ? 'active' : ''}">
                            <img src="${img}" class="d-block w-100"
                                style="height: 400px; object-fit: contain; background: #1e293b; cursor: zoom-in;"
                                alt="Product image" onclick="openImageViewer(${idx})">
                        </div>
                        `).join('')}
                    </div>
                    ${product.images.length > 1 ? `
                    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel"
                        data-bs-slide="prev">
                        <span class="carousel-control-prev-icon"></span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel"
                        data-bs-slide="next">
                        <span class="carousel-control-next-icon"></span>
                    </button>
                    ` : ''}
                </div>
                ` : `
                <div
                    style="height: 400px; background: var(--primary-gradient); display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-image" style="font-size: 100px; color: var(--text-dark);"></i>
                </div>
                `}
            </div>

            <!-- Description -->
            <div class="card p-4 mb-4">
                <h4><i class="bi bi-file-text"></i> Description</h4>
                <p class="text-muted">${product.description}</p>

                <hr>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-list" style="color: #667eea;"></i>
                            <div>
                                <div class="small text-muted">Category</div>
                                <div class="fw-bold text-capitalize">${product.category}</div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-star-fill" style="color: #f59e0b;"></i>
                            <div>
                                <div class="small text-muted">Condition</div>
                                <div class="fw-bold">${product.condition}/5</div>
                            </div>
                        </div>
                    </div>

                    ${product.ageMonths ? `
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-clock-history" style="color: #10b981;"></i>
                            <div>
                                <div class="small text-muted">Age</div>
                                <div class="fw-bold">${product.ageMonths} months</div>
                            </div>
                        </div>
                    </div>
                    ` : ''}

                    ${product.originalPrice ? `
                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-receipt" style="color: #64748b;"></i>
                            <div>
                                <div class="small text-muted">Original Price</div>
                                <div class="fw-bold">₹${product.originalPrice}</div>
                            </div>
                        </div>
                    </div>
                    ` : ''}

                    <div class="col-md-6">
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-eye" style="color: #3b82f6;"></i>
                            <div>
                                <div class="small text-muted">Views</div>
                                <div class="fw-bold">${product.views || 0}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Similar Products -->
            <div class="card p-4">
                <h5 class="mb-3"><i class="bi bi-grid"></i> Similar Products</h5>
                <div id="similarProducts" class="row g-3">
                    <div class="col-12 text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Price Card -->
            <div class="card mb-4 p-4 sticky-top" style="top: 82px;">
                <div class="mb-3">
                    <div class="small text-muted mb-1">Selling Price</div>
                    <h2 class="mb-0" style="color: #10b981;">₹${product.price}</h2>
                </div>

                ${product.ai_suggested_price ? `
                <div class="alert alert-info p-2 mb-3">
                    <i class="bi bi-robot"></i> AI Suggested: ₹${product.ai_suggested_price}
                </div>
                ` : ''}

                <hr>

                <div class="mb-3">
                    <div class="small text-muted mb-2">Seller</div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle fs-3" style="color: #667eea;"></i>
                        <div>
                            <div class="fw-bold">${product.sellerId.email.split('@')[0]}</div>
                            <div class="small text-muted">${product.sellerId.email}</div>
                        </div>
                    </div>
                </div>

                ${product.sellerId._id.toString() !== currentUserId.toString() ? `
                <!-- Buyer Actions -->
                <div class="d-grid gap-2 mb-3">
                    <a href="/chat/${product._id}" class="btn btn-gradient">
                        <i class="bi bi-chat-dots"></i> Chat with Seller
                    </a>
                    <button class="btn btn-outline-danger wishlist-toggle" data-product-id="${product._id}">
                        <i class="bi bi-heart"></i> <span class="wishlist-text">Add to Wishlist</span>
                    </button>
                    <button class="btn btn-outline-secondary" onclick="shareProduct()">
                        <i class="bi bi-share"></i> Share
                    </button>
                </div>
                ` : `
                <!-- Owner Actions -->
                <div class="alert alert-info p-2 mb-3">
                    <i class="bi bi-info-circle"></i> This is your item
                </div>
                <div class="d-grid gap-2">
                    <a href="/edit-product/${product._id}" class="btn btn-outline-primary">
                        <i class="bi bi-pencil"></i> Edit Product
                    </a>
                    ${product.status === 'available' ? `
                    <button class="btn btn-outline-success" onclick="markAsSold()">
                        <i class="bi bi-check-circle"></i> Mark as Sold
                    </button>
                    ` : ''}
                    <button class="btn btn-outline-danger" onclick="deleteProduct()">
                        <i class="bi bi-trash"></i> Delete Product
                    </button>
                </div>
                `}
            </div>

            <!-- Product Info -->
            <div class="card p-4">
                <h5 class="mb-3">
                    <i class="bi bi-info-circle"></i> Product Info
                </h5>

                <div class="mb-2">
                    <small class="text-muted">Posted on</small>
                    <div>${new Date(product.createdAt).toLocaleDateString('en-IN')}</div>
                </div>

                <div class="mb-2">
                    <small class="text-muted">Status</small>
                    <div>
                        <span
                            class="badge ${product.status === 'available' ? 'bg-success' : product.status === 'sold' ? 'bg-secondary' : 'bg-warning'} text-capitalize">
                            ${product.status}
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>

    <script>
        const productId = '${product._id}';
        const isOwner = ${ product.sellerId._id.toString() === currentUserId.toString()};

        // Load similar products
        async function loadSimilarProducts() {
            try {
                const response = await fetch(\`/api/similar-products/\${productId}\`);
        const data = await response.json();
        const container = document.getElementById('similarProducts');
        
        if (data.success && data.products.length > 0) {
            container.innerHTML = data.products.map(p => \`
                <div class="col-md-6">
                    <div class="card h-100" style="cursor: pointer;" onclick="window.location.href='/product/\${p._id}'">
                        <div style="height: 150px; background: \${p.images.length > 0 ? \`url('\${p.images[0]}') center/cover\` : 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)'}; border-radius: 10px 10px 0 0;">
                        </div>
                        <div class="card-body p-2">
                            <h6 class="card-title text-truncate mb-1">\${p.title}</h6>
                            <p class="fw-bold mb-0" style="color: #10b981;">₹\${p.price}</p>
                        </div>
                    </div>
                </div>
            \`).join('');
        } else {
            container.innerHTML = '<div class="col-12 text-center text-muted"><small>No similar products found</small></div>';
        }
    } catch (error) {
        console.error('Error loading similar products:', error);
        document.getElementById('similarProducts').innerHTML = '<div class="col-12 text-center text-muted"><small>Failed to load similar products</small></div>';
    }
}

// Wishlist functionality
if (!isOwner) {
    const wishlistBtn = document.querySelector('.wishlist-toggle');
    
    // Check if already wishlisted
    fetch(\`/api/wishlist/check/\${productId}\`)
        .then(res => res.json())
        .then(data => {
            if (data.success && data.isWishlisted) {
                wishlistBtn.innerHTML = '<i class="bi bi-heart-fill"></i> <span class="wishlist-text">Remove from Wishlist</span>';
                wishlistBtn.classList.remove('btn-outline-danger');
                wishlistBtn.classList.add('btn-danger');
            }
        });
    
    wishlistBtn.addEventListener('click', async function() {
        const isWishlisted = this.classList.contains('btn-danger');
        const method = isWishlisted ? 'DELETE' : 'POST';
        
        try {
            const response = await fetch(\`/api/wishlist/\${productId}\`, { method });
            const data = await response.json();
            
            if (data.success) {
                if (isWishlisted) {
                    this.innerHTML = '<i class="bi bi-heart"></i> <span class="wishlist-text">Add to Wishlist</span>';
                    this.classList.remove('btn-danger');
                    this.classList.add('btn-outline-danger');
                } else {
                    this.innerHTML = '<i class="bi bi-heart-fill"></i> <span class="wishlist-text">Remove from Wishlist</span>';
                    this.classList.remove('btn-outline-danger');
                    this.classList.add('btn-danger');
                }
            } else {
                alert('Error: ' + data.message);
            }
        } catch (error) {
            console.error('Error:', error);
            alert('Failed to update wishlist');
        }
    });
}

// Share product
function shareProduct() {
    const url = window.location.href;
    if (navigator.share) {
        navigator.share({
            title: '${product.title}',
            text: 'Check out this product on CampusOLX',
            url: url
        }).catch(err => console.log('Share failed:', err));
    } else {
        navigator.clipboard.writeText(url).then(() => {
            alert('Link copied to clipboard!');
        });
    }
}

// Owner actions
function markAsSold() {
    if (!confirm('Mark this product as sold?')) return;
    
    fetch(\`/api/products/\${productId}/mark-sold\`, { method: 'PATCH' })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert('Product marked as sold!');
                window.location.reload();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to update product');
        });
}

function deleteProduct() {
    if (!confirm('Are you sure you want to delete this product? This action cannot be undone.')) return;
    
    fetch(\`/api/products/\${productId}\`, { method: 'DELETE' })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert('Product deleted successfully!');
                window.location.href = '/profile';
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Failed to delete product');
        });
}

// Image viewer
function openImageViewer(index) {
    // Simple alert for now - can be enhanced with a proper lightbox later
    alert('Image zoom feature - click outside to close');
}

// Load similar products on page load
loadSimilarProducts();
    </script>
    `;
    %>
    <%- include('layout', { user, body }) %>