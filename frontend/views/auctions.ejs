body += '            <label class="form-label" style="color: #1e293b; font-weight: 600;">Description *</label>';
body += '            <textarea name="description" class="form-control" rows="3" placeholder="Describe your item in detail..." required style="color: #1e293b;"></textarea>';
body += '          </div>';
body += '          <div class="row">';
