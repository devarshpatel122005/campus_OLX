body += '              <select name="category" class="form-select" required style="color: #1e293b;">';
body += '                <option value="📚 Books & Quantums">📚 Books & Quantums</option>';
body += '                <option value="📐 Engineering Tools">📐 Engineering Tools</option>';
body += '                <option value="📱 Mobiles & Gadgets">📱 Mobiles & Gadgets</option>';
body += '                <option value="💻 Laptops & Accessories">💻 Laptops & Accessories</option>';
body += '                <option value="🚲 Bicycles & Ride-ons">🚲 Bicycles & Ride-ons</option>';
body += '                <option value="🏠 Hostel & PG Essentials">🏠 Hostel & PG Essentials</option>';
body += '                <option value="⚡ Electronics & Components">⚡ Electronics & Components</option>';
body += '                <option value="❄️ Coolers & Fans">❄️ Coolers & Fans</option>';
body += '                <option value="🎒 Bags & Luggage">🎒 Bags & Luggage</option>';
body += '                <option value="🎸 Hobbies & Music">🎸 Hobbies & Music</option>';
body += '                <option value="🔨 Auction Items">🔨 Auction Items</option>';
body += '              </select>';
body += '            </div>';
body += '            <div class="col-md-4 mb-3">';
