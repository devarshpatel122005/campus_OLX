// Place Bid Modal
body += '<div class="modal fade" id="placeBidModal" tabindex="-1">';
body += '  <div class="modal-dialog">';
body += '    <div class="modal-content glass-strong" style="background: rgba(255, 255, 255, 0.95) !important;">';
body += '      <div class="modal-header border-0">';
body += '        <h5 class="modal-title" style="color: #1e293b !important;">Place Your Bid</h5>';
body += '        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>';
body += '      </div>';
body += '      <div class="modal-body text-center">';
body += '        <div class="mb-4">';
body += '          <h6 style="color: #64748b;">Current Highest Bid</h6>';
body += '          <div class="h3 fw-bold" style="color: #667eea;" id="currentBidAmount">₹0</div>';
body += '        </div>';
body += '        <div class="mb-4">';
body += '          <label class="form-label" style="color: #1e293b; font-weight: 600;">Your Bid Amount (₹)</label>';
body += '          <input type="number" class="form-control text-center" id="bidAmount" placeholder="Enter your bid" min="1" style="color: #1e293b; font-size: 1.2rem; font-weight: 600;">';
body += '          <small style="color: #64748b;">Minimum bid increment: ₹5</small>';
body += '        </div>';
body += '      </div>';
body += '      <div class="modal-footer border-0 justify-content-center">';
body += '        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>';
body += '        <button type="button" class="btn btn-gradient" id="confirmBidBtn">Place Bid</button>';
body += '      </div>';
body += '    </div>';
body += '  </div>';
body += '</div>';

// JavaScript
body += '<script>';
body += 'console.log("Auction page JavaScript loaded");';
body += 'let currentAuctionId = null;';
body += '';
body += '// Wait for DOM to be ready';
body += 'document.addEventListener("DOMContentLoaded", function() {';
body += '  console.log("DOM loaded, attaching event listeners");';
body += '  ';
body += '  // Attach event listener to Start Auction button';
body += '  const startBtn = document.getElementById("startAuctionBtn");';
body += '  if (startBtn) {';
body += '    startBtn.addEventListener("click", createAuction);';
body += '    console.log("Start Auction button listener attached");';
body += '  }';
body += '  ';
body += '  // Attach event listener to Confirm Bid button';
body += '  const confirmBtn = document.getElementById("confirmBidBtn");';
body += '  if (confirmBtn) {';
body += '    confirmBtn.addEventListener("click", confirmBid);';
body += '  }';
body += '  ';
body += '  // Attach event listener to Refresh button';
body += '  const refreshBtn = document.getElementById("refreshAuctionsBtn");';
body += '  if (refreshBtn) {';
body += '    refreshBtn.addEventListener("click", refreshAuctions);';
body += '  }';
body += '  ';
body += '  // Attach event listeners to all Place Bid buttons';
body += '  document.querySelectorAll(".place-bid-btn").forEach(function(btn) {';
body += '    btn.addEventListener("click", function() {';
body += '      const auctionId = this.getAttribute("data-auction-id");';
body += '      const currentBid = parseFloat(this.getAttribute("data-current-bid"));';
body += '      const bidIncrement = parseFloat(this.getAttribute("data-bid-increment"));';
body += '      placeBid(auctionId, currentBid, bidIncrement);';
body += '    });';
body += '  });';
body += '  ';
body += '  // Attach event listeners to all View Details buttons';
body += '  document.querySelectorAll(".view-details-btn").forEach(function(btn) {';
body += '    btn.addEventListener("click", function() {';
body += '      const auctionId = this.getAttribute("data-auction-id");';
body += '      viewAuctionDetails(auctionId);';
body += '    });';
body += '  });';
body += '});';
body += '';

body += 'function placeBid(auctionId, currentBid, bidIncrement) {';
body += '  currentAuctionId = auctionId;';
body += '  document.getElementById("currentBidAmount").textContent = "₹" + currentBid;';
body += '  document.getElementById("bidAmount").min = currentBid + bidIncrement;';
body += '  document.getElementById("bidAmount").placeholder = "Min: ₹" + (currentBid + bidIncrement);';
body += '  new bootstrap.Modal(document.getElementById("placeBidModal")).show();';
body += '}';

body += 'function viewAuctionDetails(auctionId) {';
body += '  console.log("Loading auction details for:", auctionId);';
body += '  const modal = new bootstrap.Modal(document.getElementById("auctionDetailsModal"));';
body += '  modal.show();';
body += '  ';
body += '  const content = document.getElementById("auctionDetailsContent");';
body += '  content.innerHTML = \'<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-3">Loading...</p></div>\';';
body += '  ';
body += '  fetch("/api/auctions/" + auctionId)';
body += '  .then(function(response) { return response.json(); })';
body += '  .then(function(data) {';
body += '    if (data.success) {';
body += '      displayAuctionDetails(data.auction);';
body += '    } else {';
body += '      content.innerHTML = \'<div class="alert alert-danger">Failed to load auction details</div>\';';
body += '    }';
body += '  })';
body += '  .catch(function(error) {';
body += '    console.error("Error:", error);';
body += '    content.innerHTML = \'<div class="alert alert-danger">Error loading auction details</div>\';';
body += '  });';
body += '}';

body += 'function displayAuctionDetails(auction) {';
body += '  const content = document.getElementById("auctionDetailsContent");';
body += '  const timeRemaining = new Date(auction.endTime) - new Date();';
body += '  const hours = Math.floor(timeRemaining / (1000 * 60 * 60));';
body += '  const minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));';
body += '  const timeLeft = hours > 0 ? hours + "h " + minutes + "m" : minutes + "m";';
body += '  ';
body += '  let html = "";';
body += '  ';
body += '  // Images';
body += '  if (auction.images && auction.images.length > 0) {';
body += '    html += \'<div class="mb-4"><img src="\' + auction.images[0] + \'" class="img-fluid rounded" style="max-height: 300px; width: 100%; object-fit: cover;"></div>\';';
body += '  }';
body += '  ';
body += '  // Title and Status';
body += '  html += \'<h4 style="color: #1e293b;">\' + auction.title + \'</h4>\';';
body += '  html += \'<div class="d-flex gap-2 mb-3">\';';
body += '  html += \'  <span class="badge bg-success">LIVE</span>\';';
body += '  html += \'  <span class="badge bg-warning text-dark">\' + timeLeft + \' remaining</span>\';';
body += '  html += \'  <span class="badge bg-info">\' + auction.category + \'</span>\';';
body += '  html += \'</div>\';';
body += '  ';
body += '  // Description';
body += '  html += \'<div class="mb-4">\';';
body += '  html += \'  <h6 style="color: #64748b;">Description</h6>\';';
body += '  html += \'  <p style="color: #1e293b;">\' + auction.description + \'</p>\';';
body += '  html += \'</div>\';';
body += '  ';
body += '  // Current Bid';
body += '  html += \'<div class="row mb-4">\';';
body += '  html += \'  <div class="col-md-6">\';';
body += '  html += \'    <div class="p-3 rounded" style="background: rgba(102, 126, 234, 0.1); border: 1px solid rgba(102, 126, 234, 0.2);">\';';
body += '  html += \'      <div style="color: #64748b; font-size: 0.9rem;">Current Bid</div>\';';
body += '  html += \'      <div class="h3 fw-bold" style="color: #667eea;">₹\' + auction.currentBid + \'</div>\';';
body += '  html += \'    </div>\';';
body += '  html += \'  </div>\';';
body += '  html += \'  <div class="col-md-6">\';';
body += '  html += \'    <div class="p-3 rounded" style="background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2);">\';';
body += '  html += \'      <div style="color: #64748b; font-size: 0.9rem;">Starting Bid</div>\';';
body += '  html += \'      <div class="h3 fw-bold" style="color: #10b981;">₹\' + auction.startingBid + \'</div>\';';
body += '  html += \'    </div>\';';
body += '  html += \'  </div>\';';
body += '  html += \'</div>\';';
body += '  ';
body += '  // Seller Info';
body += '  html += \'<div class="mb-4">\';';
body += '  html += \'  <h6 style="color: #64748b;">Seller</h6>\';';
body += '  html += \'  <p style="color: #1e293b;"><i class="bi bi-person-circle me-2"></i>\' + auction.sellerId.email + \'</p>\';';
body += '  html += \'</div>\';';
body += '  ';
body += '  // Bid History';
body += '  html += \'<div class="mb-4">\';';
body += '  html += \'  <h6 style="color: #64748b;">Bid History (\' + auction.bids.length + \' bids)</h6>\';';
body += '  if (auction.bids.length > 0) {';
body += '    html += \'<div class="list-group">\';';
body += '    const sortedBids = auction.bids.sort(function(a, b) { return new Date(b.timestamp) - new Date(a.timestamp); });';
body += '    sortedBids.slice(0, 10).forEach(function(bid, index) {';
body += '      const bidTime = new Date(bid.timestamp).toLocaleString();';
body += '      const isHighest = index === 0;';
body += '      html += \'<div class="list-group-item" style="background: \' + (isHighest ? "rgba(16, 185, 129, 0.1)" : "white") + \'; border: 1px solid rgba(0,0,0,0.1);">\';';
body += '      html += \'  <div class="d-flex justify-content-between align-items-center">\';';
body += '      html += \'    <div>\';';
body += '      html += \'      <strong style="color: #1e293b;">₹\' + bid.amount + \'</strong>\';';
body += '      if (isHighest) html += \' <span class="badge bg-success ms-2">Highest</span>\';';
body += '      html += \'      <div style="color: #64748b; font-size: 0.85rem;"><i class="bi bi-person me-1"></i>\' + bid.userId.email + \'</div>\';';
body += '      html += \'    </div>\';';
body += '      html += \'    <small style="color: #94a3b8;">\' + bidTime + \'</small>\';';
body += '      html += \'  </div>\';';
body += '      html += \'</div>\';';
body += '    });';
body += '    html += \'</div>\';';
body += '    if (auction.bids.length > 10) {';
body += '      html += \'<p class="text-muted mt-2 small">Showing 10 most recent bids</p>\';';
body += '    }';
body += '  } else {';
body += '    html += \'<p style="color: #94a3b8;">No bids yet. Be the first to bid!</p>\';';
body += '  }';
body += '  html += \'</div>\';';
body += '  ';
body += '  // Watchers';
body += '  if (auction.watchers && auction.watchers.length > 0) {';
body += '    html += \'<div class="mb-4">\';';
body += '    html += \'  <h6 style="color: #64748b;"><i class="bi bi-eye me-2"></i>\' + auction.watchers.length + \' people watching</h6>\';';
body += '    html += \'</div>\';';
body += '  }';
body += '  ';
body += '  // Action Buttons';
body += '  html += \'<div class="d-flex gap-2 mt-4">\';';
body += '  html += \'  <button class="btn btn-gradient flex-fill" id="placeBidFromDetailsBtn" data-auction-id="\' + auction._id + \'" data-current-bid="\' + auction.currentBid + \'" data-bid-increment="\' + auction.bidIncrement + \'">Place Bid</button>\';';
body += '  html += \'  <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>\';';
body += '  html += \'</div>\';';
body += '  ';
body += '  content.innerHTML = html;';
body += '  ';
body += '  // Attach event listener to the Place Bid button in details modal';
body += '  const placeBidDetailsBtn = document.getElementById("placeBidFromDetailsBtn");';
body += '  if (placeBidDetailsBtn) {';
body += '    placeBidDetailsBtn.addEventListener("click", function() {';
body += '      const auctionId = this.getAttribute("data-auction-id");';
body += '      const currentBid = parseFloat(this.getAttribute("data-current-bid"));';
body += '      const bidIncrement = parseFloat(this.getAttribute("data-bid-increment"));';
body += '      bootstrap.Modal.getInstance(document.getElementById("auctionDetailsModal")).hide();';
body += '      setTimeout(function() { placeBid(auctionId, currentBid, bidIncrement); }, 300);';
body += '    });';
body += '  }';
body += '}';

body += 'function confirmBid() {';
body += '  const bidAmount = document.getElementById("bidAmount").value;';
body += '  if (!bidAmount || bidAmount <= 0) {';
body += '    alert("Please enter a valid bid amount.");';
body += '    return;';
body += '  }';
body += '  ';
body += '  fetch("/api/auctions/" + currentAuctionId + "/bid", {';
body += '    method: "POST",';
body += '    headers: { "Content-Type": "application/json" },';
body += '    body: JSON.stringify({ amount: parseFloat(bidAmount) })';
body += '  })';
body += '  .then(function(response) { return response.json(); })';
body += '  .then(function(data) {';
body += '    if (data.success) {';
body += '      alert("Bid placed successfully for ₹" + bidAmount + "!");';
body += '      bootstrap.Modal.getInstance(document.getElementById("placeBidModal")).hide();';
body += '      location.reload();';
body += '    } else {';
body += '      alert("Error: " + data.message);';
body += '    }';
body += '  })';
body += '  .catch(function(error) {';
body += '    console.error("Error:", error);';
body += '    alert("Failed to place bid");';
body += '  });';
body += '}';

body += 'function createAuction() {';
body += '  console.log("createAuction function called");';
body += '  const form = document.getElementById("createAuctionForm");';
body += '  console.log("Form element:", form);';
body += '  ';
body += '  if (!form) {';
body += '    alert("Form not found!");';
body += '    return;';
body += '  }';
body += '  ';
body += '  // Validate form';
body += '  if (!form.checkValidity()) {';
body += '    form.reportValidity();';
body += '    return;';
body += '  }';
body += '  ';
body += '  const formData = new FormData(form);';
body += '  console.log("FormData created");';
body += '  ';
body += '  console.log("Sending request to /api/auctions");';
body += '  fetch("/api/auctions", {';
body += '    method: "POST",';
body += '    body: formData';
body += '  })';
body += '  .then(function(response) {';
body += '    console.log("Response received, status:", response.status);';
body += '    return response.json();';
body += '  })';
body += '  .then(function(data) {';
body += '    console.log("Response data:", data);';
body += '    if (data.success) {';
body += '      alert("Auction created successfully!");';
body += '      bootstrap.Modal.getInstance(document.getElementById("createAuctionModal")).hide();';
body += '      location.reload();';
body += '    } else {';
body += '      alert("Error: " + data.message);';
body += '    }';
body += '  })';
body += '  .catch(function(error) {';
body += '    console.error("Error:", error);';
body += '    alert("Failed to create auction: " + error.message);';
body += '  });';
body += '}';

body += 'function refreshAuctions() {';
body += '  location.reload();';
body += '}';

// Auto-refresh timer for auction countdowns
body += 'setInterval(function() {';
body += '  document.querySelectorAll(".auction-timer").forEach(function(timer) {';
body += '    timer.style.animation = "pulse 1s ease-in-out";';
body += '    setTimeout(function() { timer.style.animation = ""; }, 1000);';
body += '  });';
body += '}, 60000);'; // Update every minute

body += '</script>';

