if (auctions && auctions.length > 0) {
    for (var i = 0; i < auctions.length; i++) {
        var auction = auctions[i];
        var timeRemaining = new Date(auction.endTime) - new Date();
        var hours = Math.floor(timeRemaining / (1000 * 60 * 60));
        var minutes = Math.floor((timeRemaining % (1000 * 60 * 60)) / (1000 * 60));
        var timeLeft = hours > 0 ? hours + 'h ' + minutes + 'm' : minutes + 'm';
        var urgentClass = hours < 2 ? 'auction-urgent' : '';
        
        body += '        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="' + (i * 100) + '">';
        body += '          <div class="card auction-card ' + urgentClass + ' h-100">';
        
        // Image section
        if (auction.images && auction.images.length > 0) {
            body += '            <div class="auction-image-container">';
            body += '              <img src="' + auction.images[0] + '" class="auction-image" alt="' + auction.title + '">';
            body += '            </div>';
        } else {
            body += '            <div class="auction-image-placeholder">';
            body += '              <i class="bi bi-hammer fs-1"></i>';
            body += '            </div>';
        }
        
        body += '            <div class="card-body">';
        body += '              <div class="d-flex justify-content-between align-items-start mb-3">';
        body += '                <span class="badge bg-success pulse-glow">LIVE</span>';
        body += '                <div class="text-end">';
        body += '                  <div class="auction-timer text-warning fw-bold">' + timeLeft + '</div>';
        body += '                  <small class="text-muted">';
        body += '                    <i class="bi bi-hammer me-1"></i>' + auction.bids.length + ' bids';
        if (auction.watchers && auction.watchers.length > 0) {
            body += '                    <span class="ms-2"><i class="bi bi-eye me-1"></i>' + auction.watchers.length + '</span>';
        }
        body += '                  </small>';
        body += '                </div>';
        body += '              </div>';
        body += '              <h5 class="card-title mb-2" style="color: #1e293b;">' + auction.title + '</h5>';
        body += '              <p class="card-text mb-3" style="color: #64748b;">' + auction.description.substring(0, 80) + (auction.description.length > 80 ? '...' : '') + '</p>';
        body += '              <div class="current-bid-section mb-3">';
        body += '                <div class="small" style="color: #64748b;">Current Bid</div>';
        body += '                <div class="h4 fw-bold" style="color: #667eea;">₹' + auction.currentBid + '</div>';
        body += '              </div>';
        
        body += '              <div class="d-flex gap-2">';
        body += '                <button class="btn btn-gradient btn-sm flex-fill place-bid-btn" data-auction-id="' + auction._id + '" data-current-bid="' + auction.currentBid + '" data-bid-increment="' + auction.bidIncrement + '">';
        body += '                  <i class="bi bi-hammer me-1"></i>Place Bid';
        body += '                </button>';
        body += '                <button class="btn btn-outline-primary btn-sm view-details-btn" data-auction-id="' + auction._id + '" title="View Details">';
        body += '                  <i class="bi bi-eye"></i>';
        body += '                </button>';
        body += '              </div>';
        body += '                  <i class="' + watchIcon + '" id="watch-icon-' + auction._id + '"></i>';
        body += '                </button>';
        body += '              </div>';
        body += '            </div>';
        body += '          </div>';
        body += '        </div>';
    }
} else {
    body += '        <div class="col-12 text-center py-5">';
    body += '          <i class="bi bi-hammer fs-1 mb-3" style="color: #94a3b8;"></i>';
    body += '          <h4 style="color: #64748b;">No Active Auctions</h4>';
    body += '          <p style="color: #94a3b8;">Be the first to create an auction!</p>';
    body += '        </div>';
}

body += '      </div>';
