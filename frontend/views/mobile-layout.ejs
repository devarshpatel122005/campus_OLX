    .wave-2 {
      width: 160px;
      height: 160px;
      animation-delay: 0.5s;
    }

    .wave-3 {
      width: 200px;
      height: 200px;
      animation-delay: 1s;
    }

    @keyframes wave-pulse {
      0% { transform: translate(-50%, -50%) scale(0.8); opacity: 1; }
