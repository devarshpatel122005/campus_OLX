<% const body=` <div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card p-4">
                <h2 class="mb-4">
                    <i class="bi bi-pencil brand-gradient"></i>
                    <span class="brand-gradient">Edit Product</span>
                </h2>

                <div id="editMessage"></div>

                <form id="editForm" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="bi bi-tag"></i> Title
                            </label>
                            <input type="text" class="form-control" id="title" value="${product.title}" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">
                                <i class="bi bi-list"></i> Category
                            </label>
                            <select class="form-select" id="category" required>
                                <option value="electronics" ${product.category==='electronics' ? 'selected' : '' }>
                                    Electronics</option>
                                <option value="books" ${product.category==='books' ? 'selected' : '' }>Books</option>
                                <option value="furniture" ${product.category==='furniture' ? 'selected' : '' }>Furniture
                                </option>
                                <option value="clothing" ${product.category==='clothing' ? 'selected' : '' }>Clothing
                                </option>
                                <option value="sports" ${product.category==='sports' ? 'selected' : '' }>Sports</option>
                                <option value="other" ${product.category==='other' ? 'selected' : '' }>Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-file-text"></i> Description
                        </label>
                        <textarea class="form-control" id="description" rows="3"
                            required>${product.description}</textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="bi bi-currency-rupee"></i> Original Price
                            </label>
                            <input type="number" class="form-control" id="originalPrice"
                                value="${product.originalPrice}" min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="bi bi-clock-history"></i> Age (months)
                            </label>
                            <input type="number" class="form-control" id="ageMonths" value="${product.ageMonths || 0}"
                                min="0" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">
                                <i class="bi bi-star"></i> Condition (1-5)
                            </label>
                            <select class="form-select" id="condition" required>
                                <option value="1" ${product.condition===1 ? 'selected' : '' }>1 - Poor</option>
                                <option value="2" ${product.condition===2 ? 'selected' : '' }>2 - Fair</option>
                                <option value="3" ${product.condition===3 ? 'selected' : '' }>3 - Good</option>
                                <option value="4" ${product.condition===4 ? 'selected' : '' }>4 - Very Good</option>
                                <option value="5" ${product.condition===5 ? 'selected' : '' }>5 - Like New</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-currency-rupee"></i> Selling Price
                        </label>
                        <input type="number" class="form-control" id="price" value="${product.price}" min="0" required>
                    </div>

                    <!-- Existing Images -->
                    ${product.images.length > 0 ? `
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-images"></i> Current Images
                        </label>
                        <div class="row g-2" id="currentImages">
                            ${product.images.map((img, idx) => `
                            <div class="col-md-3 position-relative">
                                <img src="${img}" class="img-thumbnail"
                                    style="height: 100px; width: 100%; object-fit: cover;">
                                <button type="button"
                                    class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 remove-img"
                                    data-index="${idx}">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                            `).join('')}
                        </div>
                    </div>
                    ` : ''}

                    <!-- New Images -->
                    <div class="mb-3">
                        <label class="form-label">
                            <i class="bi bi-image"></i> Add New Images
                        </label>
                        <input type="file" class="form-control" id="images" accept="image/*" multiple>
                        <div class="form-text">Upload additional product images (JPEG, PNG)</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-gradient py-2" id="submitBtn">
                            <i class="bi bi-check-circle"></i> Update Product
                        </button>
                        <a href="/profile" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    </div>

    <script>
        const productId = '${product._id}';
        let keepImages = ${ JSON.stringify(product.images)};

        // Remove image
        document.querySelectorAll('.remove-img').forEach(btn => {
            btn.addEventListener('click', function () {
                const index = parseInt(this.dataset.index);
                keepImages.splice(index, 1);
                this.closest('.col-md-3').remove();
            });
        });

        // Submit Form
        document.getElementById('editForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData();
            formData.append('title', document.getElementById('title').value);
            formData.append('description', document.getElementById('description').value);
            formData.append('price', document.getElementById('price').value);
            formData.append('originalPrice', document.getElementById('originalPrice').value);
            formData.append('category', document.getElementById('category').value);
            formData.append('condition', document.getElementById('condition').value);
            formData.append('ageMonths', document.getElementById('ageMonths').value);
            formData.append('keepImages', JSON.stringify(keepImages));

            const files = document.getElementById('images').files;
            for (let i = 0; i < files.length; i++) {
                formData.append('images', files[i]);
            }

            const submitBtn = document.getElementById('submitBtn');
            const messageDiv = document.getElementById('editMessage');

            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="bi bi-hourglass-split"></i> Updating...';

            try {
                const response = await fetch(\`/api/products/\${productId}\`, {
            method: 'PUT',
            body: formData
        });

        const data = await response.json();

        if (data.success) {
            messageDiv.innerHTML = \`
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> Product updated successfully! Redirecting...
                </div>
            \`;
            setTimeout(() => window.location.href = '/profile', 1500);
        } else {
            messageDiv.innerHTML = \`
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle"></i> \${data.message}
                </div>
            \`;
            submitBtn.disabled = false;
            submitBtn.innerHTML = '<i class="bi bi-check-circle"></i> Update Product';
        }
    } catch (error) {
        messageDiv.innerHTML = \`
            <div class="alert alert-danger">
                <i class="bi bi-x-circle"></i> Failed to update product. Please try again.
            </div>
        \`;
        submitBtn.disabled = false;
        submitBtn.innerHTML = '<i class="bi bi-check-circle"></i> Update Product';
    }
});
    </script>
    `;
    %>
    <%- include('layout', { user, body }) %>