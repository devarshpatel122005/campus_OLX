<%
var body = '';

body += '<div class="container-fluid py-4">';

// Header
body += '  <div class="row mb-4">';
body += '    <div class="col-12">';
body += '      <div class="d-flex justify-content-between align-items-center">';
body += '        <div>';
body += '          <h1 class="mb-2">🛡️ Admin Dashboard</h1>';
body += '          <p class="text-muted">Manage and verify products</p>';
body += '        </div>';
body += '        <a href="/dashboard" class="btn btn-outline-primary">';
body += '          <i class="bi bi-arrow-left me-2"></i>Back to Marketplace';
body += '        </a>';
body += '      </div>';
body += '    </div>';
body += '  </div>';

// Stats Cards
body += '  <div class="row mb-4" id="statsContainer">';
body += '    <div class="col-md-3">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <div class="d-flex justify-content-between align-items-center">';
body += '            <div>';
body += '              <p class="text-muted mb-1">Pending Review</p>';
body += '              <h3 class="mb-0" id="pendingCount">-</h3>';
body += '            </div>';
body += '            <div class="stat-icon bg-warning">';
body += '              <i class="bi bi-clock-history"></i>';
body += '            </div>';
body += '          </div>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '    <div class="col-md-3">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <div class="d-flex justify-content-between align-items-center">';
body += '            <div>';
body += '              <p class="text-muted mb-1">Approved</p>';
body += '              <h3 class="mb-0 text-success" id="approvedCount">-</h3>';
body += '            </div>';
body += '            <div class="stat-icon bg-success">';
body += '              <i class="bi bi-check-circle"></i>';
body += '            </div>';
body += '          </div>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '    <div class="col-md-3">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <div class="d-flex justify-content-between align-items-center">';
body += '            <div>';
body += '              <p class="text-muted mb-1">Rejected</p>';
body += '              <h3 class="mb-0 text-danger" id="rejectedCount">-</h3>';
body += '            </div>';
body += '            <div class="stat-icon bg-danger">';
body += '              <i class="bi bi-x-circle"></i>';
body += '            </div>';
body += '          </div>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '    <div class="col-md-3">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <div class="d-flex justify-content-between align-items-center">';
body += '            <div>';
body += '              <p class="text-muted mb-1">Total Users</p>';
body += '              <h3 class="mb-0" id="totalUsers">-</h3>';
body += '            </div>';
body += '            <div class="stat-icon bg-primary">';
body += '              <i class="bi bi-people"></i>';
body += '            </div>';
body += '          </div>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '  </div>';

// Filter Tabs
body += '  <div class="row mb-4">';
body += '    <div class="col-12">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <ul class="nav nav-pills mb-0" id="statusTabs">';
body += '            <li class="nav-item">';
body += '              <a class="nav-link active" data-status="pending" href="#">';
body += '                <i class="bi bi-clock-history me-2"></i>Pending';
body += '              </a>';
body += '            </li>';
body += '            <li class="nav-item">';
body += '              <a class="nav-link" data-status="approved" href="#">';
body += '                <i class="bi bi-check-circle me-2"></i>Approved';
body += '              </a>';
body += '            </li>';
body += '            <li class="nav-item">';
body += '              <a class="nav-link" data-status="rejected" href="#">';
body += '                <i class="bi bi-x-circle me-2"></i>Rejected';
body += '              </a>';
body += '            </li>';
body += '            <li class="nav-item">';
body += '              <a class="nav-link" data-status="all" href="#">';
body += '                <i class="bi bi-grid me-2"></i>All Products';
body += '              </a>';
body += '            </li>';
body += '          </ul>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '  </div>';

// Products List
body += '  <div class="row">';
body += '    <div class="col-12">';
body += '      <div class="card glass-strong">';
body += '        <div class="card-body">';
body += '          <div id="productsContainer">';
body += '            <div class="text-center py-5">';
body += '              <div class="spinner-border text-primary" role="status">';
body += '                <span class="visually-hidden">Loading...</span>';
body += '              </div>';
body += '            </div>';
body += '          </div>';
body += '        </div>';
body += '      </div>';
body += '    </div>';
body += '  </div>';

body += '</div>';

// Product Detail Modal
body += '<div class="modal fade" id="productModal" tabindex="-1">';
body += '  <div class="modal-dialog modal-lg">';
body += '    <div class="modal-content glass-strong" style="background: rgba(255, 255, 255, 0.95) !important;">';
body += '      <div class="modal-header border-0">';
body += '        <h5 class="modal-title" style="color: #1e293b !important;">Product Details</h5>';
body += '        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>';
body += '      </div>';
body += '      <div class="modal-body" id="modalContent" style="color: #1e293b;">';
body += '      </div>';
body += '    </div>';
body += '  </div>';
body += '</div>';

// Styles
body += '<style>';
body += '.stat-icon {';
body += '  width: 50px;';
body += '  height: 50px;';
body += '  border-radius: 12px;';
body += '  display: flex;';
body += '  align-items: center;';
body += '  justify-content: center;';
body += '  font-size: 1.5rem;';
body += '  color: white;';
body += '}';
body += '.product-card-admin {';
body += '  border: 1px solid rgba(0, 0, 0, 0.1);';
body += '  border-radius: 12px;';
body += '  padding: 1rem;';
body += '  margin-bottom: 1rem;';
body += '  transition: all 0.3s ease;';
body += '  background: rgba(255, 255, 255, 0.6);';
body += '  color: #1e293b;';
body += '}';
body += '.product-card-admin:hover {';
body += '  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);';
body += '  transform: translateY(-2px);';
body += '  background: rgba(255, 255, 255, 0.8);';
body += '}';
body += '.product-card-admin h5 {';
body += '  color: #0f172a;';
body += '}';
body += '.product-image-thumb {';
body += '  width: 100px;';
body += '  height: 100px;';
body += '  object-fit: cover;';
body += '  border-radius: 8px;';
body += '}';
body += '.status-badge {';
body += '  padding: 0.25rem 0.75rem;';
body += '  border-radius: 20px;';
body += '  font-size: 0.85rem;';
body += '  font-weight: 600;';
body += '}';
body += '.nav-pills .nav-link {';
body += '  border-radius: 8px;';
body += '  margin-right: 0.5rem;';
body += '  color: #1e293b;';
body += '  background: rgba(255, 255, 255, 0.5);';
body += '  border: 1px solid rgba(0, 0, 0, 0.1);';
body += '  transition: all 0.3s ease;';
body += '}';
body += '.nav-pills .nav-link:hover {';
body += '  background: rgba(255, 255, 255, 0.8);';
body += '  color: #0f172a;';
body += '  transform: translateY(-1px);';
body += '}';
body += '.nav-pills .nav-link.active {';
body += '  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);';
body += '  color: white !important;';
body += '  border-color: transparent;';
body += '}';
body += '</style>';

// JavaScript
body += '<script>';
body += 'let currentStatus = "pending";';

body += 'async function loadStats() {';
body += '  try {';
body += '    const response = await fetch("/api/admin/stats");';
body += '    const data = await response.json();';
body += '    if (data.success) {';
body += '      document.getElementById("pendingCount").textContent = data.stats.pendingProducts;';
body += '      document.getElementById("approvedCount").textContent = data.stats.approvedProducts;';
body += '      document.getElementById("rejectedCount").textContent = data.stats.rejectedProducts;';
body += '      document.getElementById("totalUsers").textContent = data.stats.totalUsers;';
body += '    }';
body += '  } catch (error) {';
body += '    console.error("Error loading stats:", error);';
body += '  }';
body += '}';

body += 'async function loadProducts(status) {';
body += '  currentStatus = status;';
body += '  const container = document.getElementById("productsContainer");';
body += '  container.innerHTML = \'<div class="text-center py-5"><div class="spinner-border text-primary"></div></div>\';';
body += '  ';
body += '  try {';
body += '    const url = status === "all" ? "/api/admin/products" : `/api/admin/products?status=${status}`;';
body += '    console.log("Loading products from:", url);';
body += '    const response = await fetch(url);';
body += '    const data = await response.json();';
body += '    console.log("Products loaded:", data.products?.length || 0, "products");';
body += '    ';
body += '    if (data.success && data.products.length > 0) {';
body += '      let html = "";';
body += '      data.products.forEach(product => {';
body += '        console.log("Product:", product.title, "Status:", product.status);';
body += '        const statusClass = product.status === "approved" ? "success" : product.status === "rejected" ? "danger" : product.status === "pending" ? "warning" : "info";';
body += '        const statusIcon = product.status === "approved" ? "check-circle" : product.status === "rejected" ? "x-circle" : product.status === "pending" ? "clock-history" : "info-circle";';
body += '        const statusText = product.status.toUpperCase();';
body += '        const imageUrl = product.images && product.images.length > 0 ? product.images[0] : "/uploads/placeholder.jpg";';
body += '        ';
body += '        html += `<div class="product-card-admin">`;';
body += '        html += `  <div class="row align-items-center">`;';
body += '        html += `    <div class="col-md-2">`;';
body += '        html += `      <img src="${imageUrl}" class="product-image-thumb" alt="${product.title}" onerror="this.src=\'/uploads/placeholder.jpg\'">`;';
body += '        html += `    </div>`;';
body += '        html += `    <div class="col-md-5">`;';
body += '        html += `      <h5 class="mb-1">${product.title}</h5>`;';
body += '        html += `      <p class="text-muted mb-2 small">${product.description.substring(0, 100)}...</p>`;';
body += '        html += `      <div class="d-flex gap-2 align-items-center flex-wrap">`;';
body += '        html += `        <span class="badge bg-primary">${product.category}</span>`;';
body += '        html += `        <span class="text-success fw-bold">₹${product.price}</span>`;';
body += '        html += `        <span class="text-muted small"><i class="bi bi-person me-1"></i>${product.sellerId.email}</span>`;';
body += '        html += `        <span class="text-muted small"><i class="bi bi-calendar me-1"></i>${new Date(product.createdAt).toLocaleDateString()}</span>`;';
body += '        html += `      </div>`;';
body += '        html += `    </div>`;';
body += '        html += `    <div class="col-md-2 text-center">`;';
body += '        html += `      <span class="status-badge bg-${statusClass} text-white d-inline-block">`;';
body += '        html += `        <i class="bi bi-${statusIcon} me-1"></i>${statusText}`;';
body += '        html += `      </span>`;';
body += '        html += `    </div>`;';
body += '        html += `    <div class="col-md-3 text-end">`;';
body += '        if (product.status === "pending" || product.status === "available") {';
body += '          html += `<div class="d-flex gap-2 justify-content-end">`;';
body += '          html += `  <button class="btn btn-success btn-sm" onclick="approveProduct(\'${product._id}\', \'${product.title.replace(/\'/g, "\\\\\'")}\')">`;';
body += '          html += `    <i class="bi bi-check-circle me-1"></i>Approve`;';
body += '          html += `  </button>`;';
body += '          html += `  <button class="btn btn-danger btn-sm" onclick="rejectProduct(\'${product._id}\', \'${product.title.replace(/\'/g, "\\\\\'")}\')">`;';
body += '          html += `    <i class="bi bi-x-circle me-1"></i>Reject`;';
body += '          html += `  </button>`;';
body += '          html += `</div>`;';
body += '        } else {';
body += '          html += `<button class="btn btn-outline-primary btn-sm" onclick="viewProduct(\'${product._id}\')">`;';
body += '          html += `  <i class="bi bi-eye me-1"></i>View Details`;';
body += '          html += `</button>`;';
body += '        }';
body += '        html += `    </div>`;';
body += '        html += `  </div>`;';
body += '        html += `</div>`;';
body += '      });';
body += '      container.innerHTML = html;';
body += '    } else {';
body += '      container.innerHTML = `<div class="text-center py-5"><p class="text-muted">No products found</p></div>`;';
body += '    }';
body += '  } catch (error) {';
body += '    console.error("Error loading products:", error);';
body += '    container.innerHTML = `<div class="text-center py-5"><p class="text-danger">Error loading products</p></div>`;';
body += '  }';
body += '}';

body += 'async function approveProduct(productId, title) {';
body += '  const note = prompt(`Approve "${title}"?\\nOptional note for seller:`);';
body += '  if (note === null) return;';
body += '  ';
body += '  try {';
body += '    console.log("Approving product:", productId);';
body += '    const response = await fetch(`/api/admin/products/${productId}/approve`, {';
body += '      method: "POST",';
body += '      headers: { "Content-Type": "application/json" },';
body += '      body: JSON.stringify({ note })';
body += '    });';
body += '    console.log("Response status:", response.status);';
body += '    const data = await response.json();';
body += '    console.log("Response data:", data);';
body += '    if (data.success) {';
body += '      alert("Product approved successfully!");';
body += '      loadProducts(currentStatus);';
body += '      loadStats();';
body += '    } else {';
body += '      alert("Error: " + data.message);';
body += '    }';
body += '  } catch (error) {';
body += '    console.error("Error approving product:", error);';
body += '    alert("Failed to approve product: " + error.message);';
body += '  }';
body += '}';

body += 'async function rejectProduct(productId, title) {';
body += '  const note = prompt(`Reject "${title}"?\\nReason (required):`, "Does not meet our guidelines");';
body += '  if (!note) return;';
body += '  ';
body += '  try {';
body += '    const response = await fetch(`/api/admin/products/${productId}/reject`, {';
body += '      method: "POST",';
body += '      headers: { "Content-Type": "application/json" },';
body += '      body: JSON.stringify({ note })';
body += '    });';
body += '    const data = await response.json();';
body += '    if (data.success) {';
body += '      alert("Product rejected");';
body += '      loadProducts(currentStatus);';
body += '      loadStats();';
body += '    } else {';
body += '      alert("Error: " + data.message);';
body += '    }';
body += '  } catch (error) {';
body += '    console.error("Error rejecting product:", error);';
body += '    alert("Failed to reject product");';
body += '  }';
body += '}';

body += 'function viewProduct(productId) {';
body += '  window.open(`/product/${productId}`, "_blank");';
body += '}';

body += 'document.querySelectorAll("#statusTabs .nav-link").forEach(link => {';
body += '  link.addEventListener("click", (e) => {';
body += '    e.preventDefault();';
body += '    document.querySelectorAll("#statusTabs .nav-link").forEach(l => l.classList.remove("active"));';
body += '    link.classList.add("active");';
body += '    loadProducts(link.dataset.status);';
body += '  });';
body += '});';

body += 'loadStats();';
body += 'loadProducts("pending");';
body += '</script>';
%>
<%- include('layout', { user, body }) %>
